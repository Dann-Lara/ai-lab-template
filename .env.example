# ═══════════════════════════════════════════════════════════════════════════════
# AI Lab Template — Root environment file
#
# This file is read by Docker Compose for ALL services.
# Copy to the right file depending on your environment:
#
#   Local dev:  cp .env.example .env
#   Staging:    cp .env.example .env.staging   → change URLS + secrets
#   Production: cp .env.example .env.prod      → change URLS + ALL secrets
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  Variables that CHANGE between environments are marked with [CHANGE]    │
# │  Variables that can stay the same are marked with [OK in dev]           │
# └─────────────────────────────────────────────────────────────────────────┘
# ═══════════════════════════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ailab   # [OK in dev] Changes container names prefix
APP_NAME=AI Lab
NODE_ENV=development          # [CHANGE] → staging | production

# ── Public URLs  [CHANGE per environment] ────────────────────────────────────
# These are the URLs visible from the OUTSIDE (browser, Telegram, other services)
# Dev:  http://localhost:XXXX
# Stg:  https://stg.yourdomain.com
# Prod: https://yourdomain.com

BACKEND_PUBLIC_URL=http://localhost:3001
FRONTEND_PUBLIC_URL=http://localhost:3000
N8N_WEBHOOK_URL=http://localhost:5678/   # Must end with /

# ── Ports  [OK in dev, may need to change in stg/prod if behind proxy] ────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
N8N_PORT=5678
DB_PORT=5432
REDIS_PORT=6379

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=secret              # [CHANGE in stg/prod] Use a strong password
DB_NAME=ailab
N8N_DB_NAME=n8n

# ── Redis  [CHANGE password in prod] ─────────────────────────────────────────
REDIS_PASSWORD=                 # Leave empty in dev; set in prod

# ── Auth — CHANGE ALL IN STG/PROD ────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
SUPERADMIN_EMAIL=superadmin@ailab.dev
SUPERADMIN_PASSWORD=SuperAdmin123!   # [CHANGE in stg/prod]

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=admin123                # [CHANGE in stg/prod]
N8N_ENCRYPTION_KEY=change-me-32-chars-minimum-here!!  # [CHANGE] keep same across restarts
N8N_WEBHOOK_SECRET=change-me         # [CHANGE] shared secret backend↔n8n

# n8n API Key — created in n8n UI: Settings → n8n API → Create API Key
# Used by `npm run n8n:sync` to push workflows automatically
# Leave empty to use basic auth fallback (N8N_USER / N8N_PASSWORD)
N8N_API_KEY=

# ── AI Providers — set ONE or more ───────────────────────────────────────────
# Priority order (default): gemini → groq → openai → deepseek → anthropic
# Override: AI_PROVIDER_PRIORITY=openai,gemini

GEMINI_API_KEY=           # https://aistudio.google.com/app/apikey  (free tier)
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

GROQ_API_KEY=             # https://console.groq.com  (free tier, fast)
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=           # https://platform.openai.com/api-keys
OPENAI_DEFAULT_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=         # https://platform.deepseek.com  (cheap)
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

ANTHROPIC_API_KEY=        # https://console.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

AI_PROVIDER_PRIORITY=     # Optional: gemini,groq,openai (comma-separated)

# ── Telegram  [CHANGE] ────────────────────────────────────────────────────────
# Create bot: open Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=    # Without @, e.g. MyAiLabBot

# ── Misc ──────────────────────────────────────────────────────────────────────
TIMEZONE=America/Mexico_City
CORS_ORIGINS=http://localhost:3000   # [CHANGE] → https://yourdomain.com in prod
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
N8N_LOG_LEVEL=info                   # debug | info | warn | error

# ── Frontend public vars (read by Next.js) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api  # [CHANGE] → https://yourdomain.com/api
