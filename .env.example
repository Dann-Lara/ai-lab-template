# ── Docker Compose shared vars (postgres + n8n) ──────────────────────────────
DB_USER=admin
DB_PASSWORD=secret
DB_NAME=ailab

N8N_USER=admin
N8N_PASSWORD=admin123
N8N_DB_NAME=n8n
