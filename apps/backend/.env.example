# ═══════════════════════════════════════════════════════════════════════════════
# Backend — apps/backend/.env
# Used when running the backend LOCALLY (npm run dev, not inside Docker).
#
# When running via Docker Compose, all vars come from the ROOT .env file.
# This file only needs to exist for `npm run dev` outside Docker.
# ═══════════════════════════════════════════════════════════════════════════════

PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# Database (local — not inside Docker network, so use localhost)
DATABASE_URL=postgresql://admin:secret@localhost:5432/ailab
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
SUPERADMIN_EMAIL=superadmin@ailab.dev
SUPERADMIN_PASSWORD=SuperAdmin123!

# AI Providers — see root .env.example for all options
GEMINI_API_KEY=your-gemini-key
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER_PRIORITY=

# n8n (local — n8n running on localhost, not Docker internal DNS)
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=change-me
N8N_API_KEY=
N8N_USER=admin
N8N_PASSWORD=admin123

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Public URLs
BACKEND_PUBLIC_URL=http://localhost:3001

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
