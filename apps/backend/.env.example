# ═══════════════════════════════════════════════════════════════════════════════
# Backend — apps/backend/.env
# Copy to apps/backend/.env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:secret@localhost:5432/ailab

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth — change ALL secrets in production ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Superadmin seed (auto-created on first startup) ──────────────────────────
SUPERADMIN_EMAIL=superadmin@ailab.dev
SUPERADMIN_PASSWORD=SuperAdmin123!

# ── AI Providers ─────────────────────────────────────────────────────────────
# Set ONE or MORE keys. Falls back automatically if a provider fails.
# Priority order: gemini → groq → openai → deepseek → anthropic
# Override: AI_PROVIDER_PRIORITY=openai,gemini,groq

# 1. Google Gemini (free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# 2. Groq (free tier, no credit card) — https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# 3. OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# 4. DeepSeek — https://platform.deepseek.com
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# 5. Anthropic Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Custom provider priority (optional)
# AI_PROVIDER_PRIORITY=gemini,groq,openai

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# n8n API Key for automated workflow sync (npm run n8n:sync)
# Create in n8n UI: Settings → n8n API → Create API Key
# Leave empty to fall back to basic auth (N8N_USER / N8N_PASSWORD)
N8N_API_KEY=

# n8n basic auth (used by Docker and as fallback for workflow sync)
N8N_USER=admin
N8N_PASSWORD=admin123

# ── Telegram Bot — https://t.me/BotFather ────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-your-token
TELEGRAM_BOT_USERNAME=YourBotUsername

# ── Deployment ───────────────────────────────────────────────────────────────
# Public URL of this backend (used by n8n to call your API)
BACKEND_PUBLIC_URL=http://localhost:3001

# ── Throttling ───────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
