# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:secret@localhost:5432/ailab

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth — CHANGE ALL SECRETS IN PRODUCTION ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Superadmin (auto-created on first startup) ────────────────────────────────
SUPERADMIN_EMAIL=superadmin@ailab.dev
SUPERADMIN_PASSWORD=SuperAdmin123!

# ── AI Providers ─────────────────────────────────────────────────────────────
# Set ONE or MORE keys. Providers are tried in this order unless overridden.
# Lower priority = tried first. If a provider fails (quota/auth/rate-limit),
# the next one is tried automatically.
#
# Priority order (default): gemini → groq → openai → deepseek → anthropic
# Override: AI_PROVIDER_PRIORITY=openai,gemini,groq

# 1. Google Gemini (FREE tier available — good starting point)
#    Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_NEW_KEY    # Your previous key was exposed — generate a new one at aistudio.google.com/app/apikey
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# 2. Groq (FREE tier — extremely fast, no credit card required)
#    Get key: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# 3. OpenAI
#    Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# 4. DeepSeek (very cheap, OpenAI-compatible)
#    Get key: https://platform.deepseek.com
# DEEPSEEK_API_KEY=your-deepseek-key-here
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# 5. Anthropic Claude
#    Get key: https://console.anthropic.com
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Custom priority (optional — comma-separated provider names)
# AI_PROVIDER_PRIORITY=gemini,groq,openai

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# ── Throttling ────────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
