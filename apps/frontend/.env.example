# ═══════════════════════════════════════════════════════════════════════════════
# Frontend — apps/frontend/.env.local
# Copy to apps/frontend/.env.local (Next.js convention).
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ═══════════════════════════════════════════════════════════════════════════════

# ── API ──────────────────────────────────────────────────────────────────────
# URL of the backend (used by server-side API proxy routes)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Username shown in the "How to get your Chat ID" modal (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername
